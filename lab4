CREATE PROCEDURE count_sub
    @cnt_asoi INT OUTPUT,
    @cnt_ab INT OUTPUT,
    @cnt_total INT OUTPUT,
    @cnt_same INT OUTPUT
AS BEGIN
    SELECT @cnt_asoi = COUNT(*)
    FROM hours
    JOIN faculty ON hours.faculty_id = faculty.id
    WHERE faculty.faculty_name = 'Автоматизированные системы обработки информации';

    SELECT @cnt_ab = COUNT(*)
    FROM hours
    JOIN faculty ON hours.faculty_id = faculty.id
    WHERE faculty.faculty_name = 'Экономическая безопасность';

    SELECT @cnt_total = COUNT(*) FROM hours;

    SELECT @cnt_same = COUNT(*)
    FROM hours
    GROUP BY course
    HAVING COUNT(*) > 1;

    PRINT 'Автоматизированные системы обработки информации: ' + CAST(@cnt_asoi AS NVARCHAR);
    PRINT 'Экономическая безопасность: ' + CAST(@cnt_ab AS NVARCHAR);
    PRINT 'Всего: ' + CAST(@cnt_total AS NVARCHAR);
    PRINT 'Одинаковых курсов: ' + CAST(@cnt_same AS NVARCHAR);
END
