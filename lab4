CREATE TABLE faculty (
    id INT PRIMARY KEY IDENTITY(1,1),
    faculty_name NVARCHAR(200) NOT NULL
);

CREATE TABLE form (
    id INT PRIMARY KEY IDENTITY(1,1),
    form_name NVARCHAR(200) NOT NULL
);

CREATE TABLE hours (
    id INT PRIMARY KEY IDENTITY(1,1),
    course INT NOT NULL,
    faculty_id INT NOT NULL,
    form_id INT NOT NULL,
    all_h INT,
    inclass_h INT,
    CONSTRAINT hours_faculty FOREIGN KEY (faculty_id) REFERENCES faculty(id),
    CONSTRAINT hours_form FOREIGN KEY (form_id) REFERENCES form(id)
);

CREATE TABLE stud (
    id INT PRIMARY KEY IDENTITY(1,1),
    last_name NVARCHAR(200) NOT NULL,
    f_name NVARCHAR(200) NOT NULL,
    s_name NVARCHAR(200),
    br_date DATE,
    in_date DATE,
    exm FLOAT
);

CREATE TABLE process (
    stud_id INT NOT NULL,
    hours_id INT NOT NULL,
    CONSTRAINT stud_hours PRIMARY KEY (stud_id, hours_id),
    CONSTRAINT process_stud FOREIGN KEY (stud_id) REFERENCES stud(id),
    CONSTRAINT process_hours FOREIGN KEY (hours_id) REFERENCES hours(id)
);


