SELECT stud.last_name, stud.f_name, stud.s_name, faculty.faculty_name, hours.course
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE form.form_name = 'заочная'
  AND DATEDIFF(year, stud.br_date, GETDATE()) < 37;


SELECT faculty.faculty_name, COUNT(stud.id) AS tot_students
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN process ON hours.id = process.hours_id
JOIN stud ON process.stud_id = stud.id
GROUP BY faculty.faculty_name;


SELECT form.form_name, COUNT(stud.id) AS form_c
FROM form
JOIN hours ON form.id = hours.form_id
JOIN process ON hours.id = process.hours_id
JOIN stud ON process.stud_id = stud.id
GROUP BY form.form_name;


SELECT faculty.faculty_name, AVG(DATEDIFF(year, stud.br_date, GETDATE())) AS avg_years
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN process ON hours.id = process.hours_id
JOIN stud ON process.stud_id = stud.id
GROUP BY faculty.faculty_name;


SELECT stud.last_name, stud.f_name, stud.in_date, faculty.faculty_name, hours.course, form.form_name
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE stud.s_name IS NULL;


SELECT faculty.faculty_name, COUNT(stud.id) AS zach_2015
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
WHERE YEAR(stud.in_date) = 2015
GROUP BY faculty.faculty_name
ORDER BY zach_2015 DESC;


SELECT faculty.faculty_name, form.form_name, COUNT(stud.id) AS zach_2014
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE YEAR(stud.in_date) = 2014
GROUP BY faculty.faculty_name, form.form_name;


SELECT DISTINCT faculty.faculty_name
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN form ON hours.form_id = form.id
WHERE form.form_name = 'заочная';


SELECT faculty.faculty_name, form.form_name, hours.course
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN form ON hours.form_id = form.id
ORDER BY faculty.faculty_name, form.form_name, hours.course;


SELECT faculty.faculty_name, form.form_name, COUNT(stud.id) AS stud_tot
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN form ON hours.form_id = form.id
JOIN process ON hours.id = process.hours_id
JOIN stud ON process.stud_id = stud.id
GROUP BY faculty.faculty_name, form.form_name
ORDER BY faculty.faculty_name;


SELECT faculty.faculty_name, form.form_name, COUNT(stud.id) AS stud_amt
FROM faculty
JOIN hours ON faculty.id = hours.faculty_id
JOIN form ON hours.form_id = form.id
JOIN process ON hours.id = process.hours_id
JOIN stud ON process.stud_id = stud.id
GROUP BY faculty.faculty_name, form.form_name
ORDER BY faculty.faculty_name;


SELECT faculty.faculty_name, form.form_name, COUNT(stud.id) AS crs_1_3_count
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE hours.course IN (1, 3)
GROUP BY faculty.faculty_name, form.form_name;


SELECT faculty.faculty_name, hours.course, COUNT(stud.id) AS f_cnt
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
WHERE stud.s_name IS NULL
GROUP BY faculty.faculty_name, hours.course
ORDER BY faculty.faculty_name, hours.course;


SELECT faculty.faculty_name, hours.course, COUNT(stud.id) AS high_sc
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
WHERE stud.exm > 7.5
GROUP BY faculty.faculty_name, hours.course
ORDER BY faculty.faculty_name, hours.course;


SELECT faculty.faculty_name, form.form_name, COUNT(stud.id) AS old_45
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE DATEDIFF(year, stud.br_date, GETDATE()) > 45
GROUP BY faculty.faculty_name, form.form_name
ORDER BY faculty.faculty_name;


SELECT faculty.faculty_name, form.form_name, hours.course, COUNT(stud.id) AS yng_27
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
JOIN form ON hours.form_id = form.id
WHERE DATEDIFF(year, stud.br_date, GETDATE()) < 27
GROUP BY faculty.faculty_name, form.form_name, hours.course
ORDER BY faculty.faculty_name, form.form_name, hours.course;


SELECT faculty.faculty_name, COUNT(stud.id) AS s_name
FROM stud
JOIN process ON stud.id = process.stud_id
JOIN hours ON process.hours_id = hours.id
JOIN faculty ON hours.faculty_id = faculty.id
WHERE stud.last_name LIKE N'С%'
GROUP BY faculty.faculty_name
ORDER BY faculty.faculty_name;
