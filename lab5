CREATE FUNCTION GetAge (@BirthDate DATE)
RETURNS INT
AS BEGIN
    RETURN DATEDIFF(YEAR, @BirthDate, GETDATE());
END;

SELECT FirstName, LastName, dbo.GetAge(BirthDate) AS Age
FROM Employees
WHERE dbo.GetAge(BirthDate) > 30;



CREATE FUNCTION GetProd (@CategoryName NVARCHAR(50))
RETURNS TABLE
AS RETURN
(
    SELECT Products.ProductID, Products.ProductName, Products.Price
    FROM Products 
    JOIN Categories 
    ON Categories.CategoryID = Products.CategoryID
    WHERE Categories.CategoryName = @CategoryName
);

SELECT * FROM dbo.GetProd('Овощи');


CREATE FUNCTION FormatName (@FirstName NVARCHAR(50), @LastName NVARCHAR(50))
RETURNS NVARCHAR(100)
AS BEGIN
    RETURN CONCAT(@LastName, ', ', @FirstName);
END;

SELECT dbo.FormatName(FirstName, LastName) AS Form_Name
FROM Employees;



CREATE FUNCTION GetAvgPrice (@CategoryID INT)
RETURNS INT
AS BEGIN
    RETURN (
        SELECT ISNULL(AVG(Price), 0) 
        FROM Products 
        WHERE CategoryID = @CategoryID
    );
END;

SELECT CategoryName, dbo.GetAvgPrice(CategoryID) AS Avg_Price
FROM Categories;
